# Plantilla — copiar a `.env` (sin sufijo `.example`) y completar con datos reales.
# `.env` está en .gitignore. `.env.example` SÍ se commitea, por eso no debe
# tener credenciales reales nunca.

# Credenciales de GBM+
GBM_EMAIL=tu-email@ejemplo.com
GBM_PASSWORD=tu-password-aqui

# CLIENT_ID público de la app web de GBM (no es secreto, ya está como default
# en el script — esta línea es opcional, solo por si GBM lo cambia algún día).
GBM_CLIENT_ID=7c464570619a417080b300076e163289
